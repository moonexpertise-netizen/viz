# ── Pennylane (Firm API — cabinet) ───────────────────────────────
# Token cabinet genere dans Pennylane : Reglages > Tokens du cabinet.
# Scopes requis : companies:readonly, fiscal_years:readonly, trial_balance:readonly
# (+ ledger_entries:readonly pour la vue mensuelle / tresorerie)
PENNYLANE_FIRM_TOKEN=

# ── Acces a l'application ────────────────────────────────────────
# Mot de passe partage demande au login.
APP_PASSWORD=change-me

# Secret pour signer le cookie de session (chaine aleatoire longue).
AUTH_SECRET=change-this-to-a-long-random-string
