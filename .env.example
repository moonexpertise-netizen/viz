# ── Pennylane (Firm API — cabinet) ───────────────────────────────
# Token cabinet genere dans Pennylane : Reglages > Tokens du cabinet.
# Scopes requis : companies:readonly, fiscal_years:readonly, trial_balance:readonly
# (+ ledger_entries:readonly pour la vue mensuelle / tresorerie)
PENNYLANE_FIRM_TOKEN=

# Token dédié au dossier MOON EXPERTISE (compte individuel, API v2). Optionnel :
# si présent, MOON EXPERTISE apparaît dans la liste avec les mêmes vues.
PENNYLANE_MOON_TOKEN=

# ── Acces a l'application ────────────────────────────────────────
# Secret pour signer le cookie de session (chaine aleatoire longue).
AUTH_SECRET=change-this-to-a-long-random-string
# Mot de passe de secours (utilise si aucun mot de passe n'est defini via le reset).
APP_PASSWORD=change-me
# Domaine e-mail autorise a se connecter.
ALLOWED_EMAIL_DOMAIN=moonexpertise.fr
# Base des liens e-mail (evite l'empoisonnement d'en-tete Host).
APP_URL=https://viz.moonexpertise.fr
# Administrateur : recoit les demandes d'acces et peut approuver/refuser.
ADMIN_EMAIL=benjamin.perez@moonexpertise.fr

# ── Reset mot de passe par e-mail (optionnel) ────────────────────
# Cle API Resend + adresse expediteur (domaine verifie dans Resend).
RESEND_API_KEY=
RESET_FROM=MoonViz <noreply@moonexpertise.fr>

# ── Stockage serveur (optionnel : exercices synchronises durables + reset mdp) ──
# Auto-injectees en creant un store Vercel KV / Upstash Redis (Storage > Create).
KV_REST_API_URL=
KV_REST_API_TOKEN=
