# ── Pennylane (Firm API — cabinet) ───────────────────────────────
# Token cabinet genere dans Pennylane : Reglages > Tokens du cabinet.
# Scopes requis : companies:readonly, fiscal_years:readonly, trial_balance:readonly
# (+ ledger_entries:readonly pour la vue mensuelle / tresorerie)
PENNYLANE_FIRM_TOKEN=

# Token dédié au dossier MOON EXPERTISE (compte individuel, API v2). Optionnel :
# si présent, MOON EXPERTISE apparaît dans la liste avec les mêmes vues.
PENNYLANE_MOON_TOKEN=

# ── Acces a l'application ────────────────────────────────────────
# Secret pour signer le cookie de session (chaine aleatoire longue).
AUTH_SECRET=change-this-to-a-long-random-string

# Repli mot de passe (utilise UNIQUEMENT si le SSO Microsoft n'est pas configure).
APP_PASSWORD=change-me

# ── SSO Microsoft Entra (recommande) ─────────────────────────────
# Connexion restreinte aux comptes du tenant + au domaine ci-dessous.
# Cree une "App registration" dans Azure (Entra ID), redirect URI :
#   https://viz.moonexpertise.fr/api/auth/callback  (et l'URL .vercel.app)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=moonexpertise.fr
